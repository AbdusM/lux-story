{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lux-story.local/docs/audits/AUDIT_OUTPUT_SCHEMA.json",
  "title": "Lux Story Audit Output Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "audit_version",
    "generated_at",
    "project_type",
    "audit_modes",
    "depth",
    "risk_tolerance",
    "scope",
    "baseline_snapshot",
    "findings",
    "root_cause_clusters",
    "fix_queue",
    "summary"
  ],
  "properties": {
    "audit_version": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "project_type": {
      "type": "string",
      "minLength": 1
    },
    "audit_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "depth": {
      "type": "string",
      "enum": [
        "surface",
        "standard",
        "deep"
      ]
    },
    "risk_tolerance": {
      "type": "string",
      "enum": [
        "prototype",
        "production",
        "regulated"
      ]
    },
    "changed_since": {
      "type": [
        "string",
        "null"
      ]
    },
    "scope": {
      "$ref": "#/$defs/scope"
    },
    "baseline_snapshot": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "root_cause_clusters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rootCauseCluster"
      }
    },
    "fix_queue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/auditTicket"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "integrity",
        "security",
        "reliability",
        "maintainability",
        "ux",
        "growth",
        "compliance"
      ]
    },
    "certainty": {
      "type": "string",
      "enum": [
        "observed",
        "inferred"
      ]
    },
    "issueType": {
      "type": "string",
      "enum": [
        "code_defect",
        "runtime_config_mismatch",
        "content_gap",
        "data_drift",
        "process_gap",
        "test_gap",
        "unknown"
      ]
    },
    "evidenceGrade": {
      "type": "string",
      "enum": [
        "E0",
        "E1",
        "E2"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "severity",
        "category",
        "issue_type",
        "certainty",
        "impact",
        "evidence",
        "root_cause",
        "fix",
        "verification"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "issue_type": {
          "$ref": "#/$defs/issueType"
        },
        "certainty": {
          "$ref": "#/$defs/certainty"
        },
        "evidence_grade": {
          "$ref": "#/$defs/evidenceGrade"
        },
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "root_cause": {
          "type": "string",
          "minLength": 1
        },
        "fix": {
          "type": "string",
          "minLength": 1
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prod_verification": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rootCauseCluster": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "summary",
        "finding_ids",
        "primary_fix"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "finding_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "primary_fix": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "auditTicket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "priority",
        "title",
        "category",
        "issue_type",
        "certainty",
        "description",
        "evidence",
        "root_cause",
        "proposed_fix",
        "acceptance_criteria",
        "verification_steps",
        "risk",
        "effort",
        "owner_type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "$ref": "#/$defs/severity"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "issue_type": {
          "$ref": "#/$defs/issueType"
        },
        "certainty": {
          "$ref": "#/$defs/certainty"
        },
        "evidence_grade": {
          "$ref": "#/$defs/evidenceGrade"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "root_cause": {
          "type": "string",
          "minLength": 1
        },
        "cluster_id": {
          "type": "string"
        },
        "proposed_fix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification_steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prod_verification": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "effort": {
          "type": "string",
          "enum": [
            "S",
            "M",
            "L"
          ]
        },
        "owner_type": {
          "type": "string",
          "enum": [
            "eng",
            "content",
            "ops",
            "design"
          ]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rollback": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "top_3_risks",
        "top_3_quick_wins",
        "human_verification_needed"
      ],
      "properties": {
        "top_3_risks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "top_3_quick_wins": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "human_verification_needed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "recommended_next_run": {
          "type": "string"
        }
      }
    }
  }
}
